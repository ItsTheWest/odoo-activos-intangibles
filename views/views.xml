<odoo>
  <data>
    <!-- ========================================================= -->
    <!-- 1. VISTA DE FORMULARIO (FORM VIEW)                        -->
    <!-- ========================================================= -->
    <!-- <record>: Crea un registro en la base de datos de Odoo. 
         'model="ir.ui.view"' le dice a Odoo que este registro es una vista de interfaz de usuario. -->
    <record id="view_activo_intangible_form" model="ir.ui.view">
      <field name="name">activo.intangible.form</field>  <!-- <field name="name">: Nombre técnico interno de la vista. -->
      <field name="model">activo.intangible</field>  <!-- <field name="model">: Indica a qué tabla (modelo de Python) pertenece esta vista. -->
      <field name="arch" type="xml">   <!-- <field name="arch" type="xml">: Aquí dentro va la arquitectura visual de la vista en código XML. -->
        <form string="Activo Intangible">
          <!-- <header>: Es la barra gris superior. Se usa para botones de acción y la barra de estado (workflow). -->
            <!-- ========================================================= -->
            <!-- 1.1 CABECERA (HEADER): Botones de acción y barra de estado -->
            <!-- ========================================================= -->
            <header>
            <button name="action_inactivar" string="Desactivar" type="object" class="me-2" invisible="state not in ('activo', 'por_expirar')"/>
            <button name="action_renovar" string="Activar" type="object" class="oe_highlight me-2" invisible="state not in ('inactivo', 'expirado', 'por_expirar')" confirm="¿Está seguro de que desea activar este activo? Por favor, verifique que la fecha de renovación sea correcta."/>
            
            <!-- <field widget="statusbar">: Muestra el campo 'state' como una línea de tiempo (Activo -> Inactivo) en la esquina superior derecha. -->
            <field name="state" widget="statusbar" statusbar_visible="activo,por_expirar,expirado,inactivo"/>
          </header>
          <!-- ========================================================= -->
          <!-- 1.2 CUERPO (SHEET): Contenido principal del formulario    -->
          <!-- ========================================================= -->
          <sheet>
            <style>
                .hide_add_button .o_kanban_record_add {
                    display: none !important;
                }
            </style>

            <!-- =====================================================
                 SMART BUTTON BOX — shows document count badge.
                 Clicking opens a filtered list of ir.attachment for
                 this specific asset record.
                 ===================================================== -->
            <div class="oe_button_box" name="button_box">
              <!-- Smart buttons irán aquí si hay otros en el futuro -->
            </div>

            <!-- <div class="oe_title">: Clase CSS estándar de Odoo para el título principal del registro. -->
            <!-- TÍTULO: Nombre del activo editable solo en modo edición -->
            <div class="oe_title mb-4">
              <label for="name" class="oe_edit_only" string="Nombre del Activo"/>
              <h1>
                <field name="name" placeholder="Ej. Software de Contabilidad..."/>
              </h1>
            </div>

            <!-- <group>: Organiza los campos en dos columnas. -->
            <!-- CONTENEDOR DE GRUPOS: Organiza los campos principales en columnas -->
            <group>
              <group string="Datos Generales">
                <field name="asset_type_id"/>
                <field name="registration_number" placeholder="Ej. REG-12345"/>
              </group>

              <group string="Fechas Clave">
                <field name="concession_date"/>
                <field name="renewal_date"/>
              </group>
            </group>

            <!-- <notebook>: Sección inferior con pestañas. -->
            <!-- PANELES DE PESTAÑAS (NOTEBOOK): Información complementaria -->
            <notebook>
              <!-- TAB 1: Información Adicional -->
              <page string="Información Adicional">
                <group>
                  <field name="responsible_id" widget="many2one_avatar"/>
                  <field name="expense_id"/>
                </group>
              </page>

              <!-- TAB 2: Evidencias Digitales
                   Uses the native many2many_binary widget which renders
                   an inline file list + upload button backed by ir.attachment.
                   No extra Python field or DB table is required. -->
              <page string="Evidencias Digitales" name="page_evidence">
                <!-- BOTÓN DE ACCIÓN: Abre el wizard para cargar documentos -->
                <button name="action_open_attachment_wizard" type="object" string="Adjuntar Archivos" class="btn-primary mb-3" icon="fa-upload"/>
                <!-- LISTADO DE EVIDENCIAS: Vista Kanban integrada de archivos adjuntos -->
                <field name="attachment_ids" mode="kanban" nolabel="1" class="hide_add_button" options="{'no_create': True, 'no_edit': True, 'no_open': True}">
                    <kanban create="0" edit="0" delete="0" link="0">
                        <field name="id"/>
                        <field name="mimetype"/>
                        <field name="type"/>
                        <field name="name"/>
                        <field name="url"/>
                        <templates>
                            <t t-name="card" class="o_kanban_attachment flex-row p-0 overflow-hidden">
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a type="object" name="action_preview_modal" class="dropdown-item">Vista Previa</a>
                                        <a type="object" name="action_delete_attachment_confirm" class="dropdown-item text-danger">Eliminar</a>
                                    </div>
                                </div>
                                <aside class="o_kanban_image bg-light d-flex align-items-center justify-content-center" style="width: 120px; min-width: 120px; height: 100px;">
                                    <t t-set="webimage" t-value="new RegExp('image.*(gif|jpeg|jpg|png|webp)').test(record.mimetype.value)"/>
                                    <div t-if="record.type.raw_value == 'url'" class="fa fa-link fa-3x text-muted"/>
                                    <img t-elif="webimage" t-attf-src="/web/image/#{record.id.raw_value}" style="width: 100%; height: 100%; object-fit: cover;" alt="Document"/>
                                    <div t-else="" class="o_image o_image_thumbnail" t-att-data-mimetype="record.mimetype.value"/>
                                </aside>
                                <main class="p-2 d-flex flex-column justify-content-center flex-grow-1 overflow-hidden">
                                    <field name="name" class="text-truncate fw-bold mb-1" style="font-size: 1.1rem;"/>
                                    <div class="text-muted small">
                                        <t t-if="record.type.raw_value == 'url'">
                                            <i class="fa fa-globe me-1"/> <field name="url" widget="url"/>
                                        </t>
                                        <t t-else="">
                                            <field name="mimetype"/>
                                        </t>
                                    </div>
                                </main>
                            </t>
                        </templates>
                    </kanban>
                </field>
              </page>
            </notebook>
            
          </sheet>
        </form>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 2. VISTA DE LISTA (TREE / LIST VIEW)                      -->
    <!-- ========================================================= -->
    <record id="view_activo_intangible_list" model="ir.ui.view">
      <field name="name">activo.intangible.list</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <!-- VISTA DE TABLA: Configuración de colores y columnas para el listado principal -->
        <list string="Activos Intangibles"
              decoration-success="state == 'activo'"
              decoration-warning="state == 'por_expirar'"
              decoration-info="state == 'inactivo'"
              decoration-danger="state == 'expirado'">
          <field name="name"/>
          <field name="asset_type_id"/>
          <field name="registration_number"/>
          <field name="concession_date"/>
          <field name="renewal_date"/>
          <field name="responsible_id" widget="many2one_avatar"/>
          <field name="expense_id"/>
          <!-- widget="badge": Transforma el texto del estado en una etiqueta de color. -->
          <field name="state" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'por_expirar'" decoration-info="state == 'inactivo'" decoration-danger="state == 'expirado'"/>
          <!-- Docs column: optional so it does not clutter narrow screens. -->
          <field name="document_count" string="Docs." optional="show"/>
        </list>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 3. VISTA DE BÚSQUEDA (SEARCH VIEW)                        -->
    <!-- ========================================================= -->
    <record id="view_activo_intangible_search" model="ir.ui.view">
      <field name="name">activo.intangible.search</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <!-- VISTA DE BÚSQUEDA: Definición de filtros rápidos y agrupamientos -->
        <search string="Buscar Activos Intangibles">
          <field name="name"/>
          <field name="responsible_id"/>

          <filter string="Activos" name="filter_activo" domain="[('state', '=', 'activo')]"/>
          <filter string="Por Expirar" name="filter_por_expirar" domain="[('state', '=', 'por_expirar')]"/>
          <filter string="Expirados" name="filter_expirado" domain="[('state', '=', 'expirado')]"/>
          <filter string="Inactivos" name="filter_inactivo" domain="[('state', '=', 'inactivo')]"/>

          <group>
            <filter string="Tipo de Activo" name="group_by_asset_type" context="{'group_by':'asset_type_id'}"/>
            <filter string="Estado" name="group_by_state" context="{'group_by':'state'}"/>
            <filter string="Responsable" name="group_by_responsible" context="{'group_by':'responsible_id'}"/>
          </group>
        </search>
      </field>
    </record>


    <!-- ========================================================= -->
    <!-- 4. ACCIÓN DE VENTANA (WINDOW ACTION)                      -->
    <!-- ========================================================= -->
    <!-- Las acciones son lo que Odoo ejecuta cuando haces clic en un menú. Unen los menús con las vistas. -->
    <record id="action_activo_intangible" model="ir.actions.act_window">
      <field name="name">Activos Intangibles</field>
      <field name="res_model">activo.intangible</field>
      <!-- ACCIÓN PRINCIPAL: Define el comportamiento al abrir el módulo (orden de vistas y mensaje de ayuda) -->
      <field name="view_mode">list,calendar,form</field>
      <field name="search_view_id" ref="view_activo_intangible_search"/>
      <!-- <help>: El mensaje que aparece cuando no hay ningún registro creado (pantalla vacía). -->
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea tu primer activo intangible!
        </p>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 5. MENÚS (MENUITEMS)                                      -->
    <!-- ========================================================= -->
    <!-- <menuitem>: Los botones de navegación en la barra superior o lateral. -->
    <!-- MENÚ PRINCIPAL: Nodo raíz del módulo -->
    <menuitem id="menu_activo_intangible_root" 
            name="Activos Intangibles" 
            sequence="10"/>
            
    <!-- SUBMENÚ ACTIVOS: Enlace directo a la gestión de registros -->
    <menuitem id="menu_activo_intangible" 
        name="Activos" 
        action="action_activo_intangible" 
        parent="menu_activo_intangible_root"
        sequence="10"/>

    <menuitem id="menu_activo_intangible_config"
        name="Configuración"
        parent="menu_activo_intangible_root"
        sequence="100"/>


    <!-- ========================================================= -->
    <!-- 7. VISTAS DE PREVISUALIZACIÓN DE DOCUMENTOS (MODAL)       -->
    <!-- ========================================================= -->
    <!-- Vista Kanban personalizada para attachments con botón de vista previa heredada -->
    <record id="view_attachment_custom_kanban" model="ir.ui.view">
      <field name="name">ir.attachment.custom.kanban</field>
      <field name="model">ir.attachment</field>
      <field name="inherit_id" ref="mail.view_document_file_kanban"/>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <!-- KANBAN HEREDADO: Añade botón de vista previa al menú de cada archivo -->
        <xpath expr="//t[@t-name='menu']" position="inside">
            <a type="object" name="action_preview_modal" class="dropdown-item">Vista Previa</a>
            <a type="delete" class="dropdown-item">Eliminar</a>
        </xpath>
      </field>
    </record>

    <!-- Vista Lista personalizada para attachments con botón de vista previa -->
    <record id="view_attachment_custom_list" model="ir.ui.view">
      <field name="name">ir.attachment.custom.list</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <list string="Documentos Adjuntos">
          <field name="name"/>
          <field name="mimetype"/>
          <field name="create_date" string="Fecha de Carga"/>
          <!-- Botón de sub-opción para vista previa modal -->
          <button name="action_preview_modal" type="object" string="Vista Previa" icon="fa-eye" class="btn-primary"/>
          <button type="delete" string="Eliminar" icon="fa-trash" class="btn-danger"/>
        </list>
      </field>
    </record>

    <!-- Vista de formulario modal para mostrar el archivo/imagen -->
    <record id="view_attachment_preview_form" model="ir.ui.view">
      <field name="name">ir.attachment.preview.form</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <form string="Vista Previa" create="false" edit="false" delete="false">
          <sheet>
            <div class="text-center">
              <h2 class="mb-4"><field name="name" readonly="1"/></h2>
              <!-- Imagen -->
              <field name="datas" widget="image" readonly="1"
                     invisible="mimetype not in ('image/jpeg', 'image/png', 'image/gif', 'image/webp')"
                     style="max-width: 100%; height: auto; border-radius: 8px;"/>
              <!-- PDF -->
              <field name="datas" widget="pdf_viewer" readonly="1"
                     invisible="mimetype != 'application/pdf'"
                     style="width: 100%; height: 600px;"/>
              <!-- Sin previsualización -->
              <div invisible="mimetype in ('image/jpeg', 'image/png', 'image/gif', 'image/webp', 'application/pdf')"
                   class="alert alert-warning mt-4">
                <strong>Atención:</strong> No hay vista previa disponible para este tipo de archivo
                (<field name="mimetype" readonly="1"/>).
                Por favor, descargue el archivo.
              </div>
            </div>
          </sheet>
          <footer>
            <button string="Cerrar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard para Adjuntar Archivos -->
    <record id="view_activo_attachment_wizard_form" model="ir.ui.view">
      <field name="name">activo.attachment.wizard.form</field>
      <field name="model">activo.attachment.wizard</field>
      <field name="arch" type="xml">
        <!-- WIZARD CARGA: Interfaz para subir múltiples archivos simultáneamente -->
        <form string="Adjuntar Archivos">
          <sheet>
             <p class="text-muted">Seleccione los documentos digitales que desea vincular a este activo.</p>
             <field name="wizard_attachment_ids" widget="many2many_binary" nolabel="1"/>
          </sheet>
          <footer>
            <button name="action_save_attachments" string="Guardar Evidencias" type="object" class="btn-primary" icon="fa-save"/>
            <button string="Cancelar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard de Confirmación: Eliminar Evidencia -->
    <record id="view_activo_delete_attachment_wizard_form" model="ir.ui.view">
      <field name="name">activo.delete.attachment.wizard.form</field>
      <field name="model">activo.delete.attachment.wizard</field>
      <field name="arch" type="xml">
        <!-- WIZARD ELIMINACIÓN: Modal de confirmación para borrado permanente -->
        <form string="Eliminar Evidencia">
          <sheet>
            <div class="o_form_view text-center py-4">
              <span class="fa fa-exclamation-triangle fa-3x text-warning mb-3 d-block"/>
              <h4>¿Está seguro de que desea eliminar este archivo?</h4>
              <p class="text-muted mt-2">
                El archivo <strong><field name="attachment_name" readonly="1" nolabel="1"/></strong>
                será eliminado de forma permanente. Esta acción no se puede deshacer.
              </p>
            </div>
          </sheet>
          <footer>
            <button name="action_confirm_delete" string="Sí, Eliminar" type="object" class="btn-danger" icon="fa-trash"/>
            <button string="Cancelar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

  </data>
</odoo>
