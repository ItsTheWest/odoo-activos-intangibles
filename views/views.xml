<odoo>
  <data>
    <!-- ========================================================= -->
    <!-- 3. VISTA DE BÚSQUEDA (SEARCH VIEW)                        -->
    <!-- ========================================================= -->
    <record id="view_activo_intangible_search" model="ir.ui.view">
      <field name="name">activo.intangible.search</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <!-- VISTA DE BÚSQUEDA: Definición de filtros rápidos y agrupamientos -->
        <search string="Buscar Activos Intangibles">
          <field name="name"/>
          <field name="responsible_id"/>

          <filter string="Activos" name="filter_activo" domain="[('state', '=', 'activo')]"/>
          <filter string="Por Expirar" name="filter_por_expirar" domain="[('state', '=', 'por_expirar')]"/>
          <filter string="Expirados" name="filter_expirado" domain="[('state', '=', 'expirado')]"/>
          <filter string="Inactivos" name="filter_inactivo" domain="[('state', '=', 'inactivo')]"/>

          <group>
            <filter string="Tipo de Activo" name="group_by_asset_type" context="{'group_by':'asset_type_id'}"/>
            <filter string="Estado" name="group_by_state" context="{'group_by':'state'}"/>
            <filter string="Responsable" name="group_by_responsible" context="{'group_by':'responsible_id'}"/>
          </group>
        </search>
      </field>
    </record>


    <!-- ========================================================= -->
    <!-- 4. ACCIÓN DE VENTANA (WINDOW ACTION)                      -->
    <!-- ========================================================= -->
    <!-- Las acciones son lo que Odoo ejecuta cuando haces clic en un menú. Unen los menús con las vistas. -->
    <record id="action_activo_intangible" model="ir.actions.act_window">
      <field name="name">Activos Intangibles</field>
      <field name="res_model">activo.intangible</field>
      <!-- ACCIÓN PRINCIPAL: Define el comportamiento al abrir el módulo (orden de vistas y mensaje de ayuda) -->
      <field name="view_mode">list,calendar,form</field>
      <field name="search_view_id" ref="view_activo_intangible_search"/>
      <!-- <help>: El mensaje que aparece cuando no hay ningún registro creado (pantalla vacía). -->
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Crea tu primer activo intangible!
        </p>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 5. MENÚS (MENUITEMS)                                      -->
    <!-- ========================================================= -->
    <!-- <menuitem>: Los botones de navegación en la barra superior o lateral. -->
    <!-- MENÚ PRINCIPAL: Nodo raíz del módulo -->
    <menuitem id="menu_activo_intangible_root" 
            name="Activos Intangibles" 
            sequence="10"/>
            
    <!-- SUBMENÚ ACTIVOS: Enlace directo a la gestión de registros -->
    <menuitem id="menu_activo_intangible" 
        name="Activos" 
        action="action_activo_intangible" 
        parent="menu_activo_intangible_root"
        sequence="10"/>

    <menuitem id="menu_activo_intangible_config"
        name="Configuración"
        parent="menu_activo_intangible_root"
        sequence="100"/>



    <!-- ========================================================= -->
    <!-- 7. VISTAS DE PREVISUALIZACIÓN DE DOCUMENTOS (MODAL)       -->
    <!-- ========================================================= -->
    <!-- Vista Kanban personalizada para attachments con botón de vista previa heredada -->
    <record id="view_attachment_custom_kanban" model="ir.ui.view">
      <field name="name">ir.attachment.custom.kanban</field>
      <field name="model">ir.attachment</field>
      <field name="inherit_id" ref="mail.view_document_file_kanban"/>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <!-- KANBAN HEREDADO: Añade botón de vista previa al menú de cada archivo -->
        <xpath expr="//t[@t-name='menu']" position="inside">
            <a type="object" name="action_preview_modal" class="dropdown-item">Vista Previa</a>
            <a type="delete" class="dropdown-item">Eliminar</a>
        </xpath>
      </field>
    </record>

    <!-- Vista Lista personalizada para attachments con botón de vista previa -->
    <record id="view_attachment_custom_list" model="ir.ui.view">
      <field name="name">ir.attachment.custom.list</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <list string="Documentos Adjuntos">
          <field name="name"/>
          <field name="mimetype"/>
          <field name="create_date" string="Fecha de Carga"/>
          <!-- Botón de sub-opción para vista previa modal -->
          <button name="action_preview_modal" type="object" string="Vista Previa" icon="fa-eye" class="btn-primary"/>
          <button type="delete" string="Eliminar" icon="fa-trash" class="btn-danger"/>
        </list>
      </field>
    </record>

    <!-- Vista de formulario modal para mostrar el archivo/imagen -->
    <record id="view_attachment_preview_form" model="ir.ui.view">
      <field name="name">ir.attachment.preview.form</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <form string="Vista Previa" create="false" edit="false" delete="false">
          <sheet>
            <div class="text-center">
              <h2 class="mb-4"><field name="name" readonly="1"/></h2>
              <!-- Imagen -->
              <field name="datas" widget="image" readonly="1"
                     invisible="mimetype not in ('image/jpeg', 'image/png', 'image/gif', 'image/webp')"
                     style="max-width: 100%; height: auto; border-radius: 8px;"/>
              <!-- PDF -->
              <field name="datas" widget="pdf_viewer" readonly="1"
                     invisible="mimetype != 'application/pdf'"
                     style="width: 100%; height: 600px;"/>
              <!-- Sin previsualización -->
              <div invisible="mimetype in ('image/jpeg', 'image/png', 'image/gif', 'image/webp', 'application/pdf')"
                   class="alert alert-warning mt-4">
                <strong>Atención:</strong> No hay vista previa disponible para este tipo de archivo
                (<field name="mimetype" readonly="1"/>).
                Por favor, descargue el archivo.
              </div>
            </div>
          </sheet>
          <footer>
            <button string="Cerrar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard para Adjuntar Archivos -->
    <record id="view_activo_attachment_wizard_form" model="ir.ui.view">
      <field name="name">activo.attachment.wizard.form</field>
      <field name="model">activo.attachment.wizard</field>
      <field name="arch" type="xml">
        <!-- WIZARD CARGA: Interfaz para subir múltiples archivos simultáneamente -->
        <form string="Adjuntar Archivos">
          <sheet>
             <p class="text-muted">Seleccione los documentos digitales que desea vincular a este activo.</p>
             <field name="wizard_attachment_ids" widget="many2many_binary" nolabel="1"/>
          </sheet>
          <footer>
            <button name="action_save_attachments" string="Guardar Evidencias" type="object" class="btn-primary" icon="fa-save"/>
            <button string="Cancelar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard de Confirmación: Eliminar Evidencia -->
    <record id="view_activo_delete_attachment_wizard_form" model="ir.ui.view">
      <field name="name">activo.delete.attachment.wizard.form</field>
      <field name="model">activo.delete.attachment.wizard</field>
      <field name="arch" type="xml">
        <!-- WIZARD ELIMINACIÓN: Modal de confirmación para borrado permanente -->
        <form string="Eliminar Evidencia">
          <sheet>
            <div class="o_form_view text-center py-4">
              <span class="fa fa-exclamation-triangle fa-3x text-warning mb-3 d-block"/>
              <h4>¿Está seguro de que desea eliminar este archivo?</h4>
              <p class="text-muted mt-2">
                El archivo <strong><field name="attachment_name" readonly="1" nolabel="1"/></strong>
                será eliminado de forma permanente. Esta acción no se puede deshacer.
              </p>
            </div>
          </sheet>
          <footer>
            <button name="action_confirm_delete" string="Sí, Eliminar" type="object" class="btn-danger" icon="fa-trash"/>
            <button string="Cancelar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard de Confirmación: Activo Próximo a Vencer -->
    <record id="view_activo_near_expiry_wizard_form" model="ir.ui.view">
      <field name="name">activo.near.expiry.wizard.form</field>
      <field name="model">activo.near.expiry.wizard</field>
      <field name="arch" type="xml">
        <!--
          WIZARD NEAR EXPIRY: Displayed when renewal_date is within 60 days on creation.
          Forces the user to make an explicit, conscious decision before the record is saved.
        -->
        <form string="Activo Próximo a Vencer">
          <field name="action_type" invisible="1"/>
          <sheet>
            <div class="o_form_view text-center py-4">
              <span class="fa fa-exclamation-triangle fa-4x text-warning mb-3 d-block"/>
              <h3 class="text-warning">Atención: Activo Próximo a Vencer</h3>
              <p class="mt-3">El activo <strong><field name="name" readonly="1" nolabel="1"/></strong>
                tiene una fecha de renovación de <strong><field name="renewal_date" readonly="1" nolabel="1"/></strong>,
                lo que significa que <strong>vence en <field name="days_left" readonly="1" nolabel="1"/> día(s)</strong>.
              </p>
              <p class="text-muted mt-2" invisible="action_type == 'activate'">
                Este activo será registrado en estado <strong>"Por Expirar"</strong>.
                ¿Desea continuar de todas formas?
              </p>
              <p class="text-danger mt-2 fw-bold" invisible="action_type == 'create'">
                No es posible activar este activo porque su fecha de renovación es menor o igual a 60 días. Por favor, actualice la fecha de renovación antes de intentar activarlo.
              </p>
            </div>
          </sheet>
          <footer>
            <button name="action_confirm" string="Sí, Continuar de Todas Formas" type="object" class="btn-warning" icon="fa-check" invisible="action_type == 'activate'"/>
            <button string="Cancelar" class="btn-secondary" special="cancel" invisible="action_type == 'activate'"/>
            <button string="Entendido" class="btn-primary" special="cancel" invisible="action_type == 'create'"/>
          </footer>
        </form>
      </field>
    </record>

  </data>
</odoo>

