<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ========================================================= -->
        <!-- KANBAN VIEW FOR RISK ANALYSIS                             -->
        <!-- ========================================================= -->
        <record id="view_activo_intangible_risk_kanban" model="ir.ui.view">
            <field name="name">activo.intangible.risk.kanban</field>
            <field name="model">activo.intangible</field>
            <field name="arch" type="xml">
                <kanban default_group_by="nivel_riesgo" class="o_kanban_small_column" records_draggable="false" quick_create="false">
                    <field name="name"/>
                    <field name="asset_type_id"/>
                    <field name="nivel_riesgo"/>
                    <field name="state"/>
                    <field name="valor_contable"/>
                    <field name="currency_id"/>
                    <field name="renewal_date"/>
                    <field name="responsible_id"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_global_click oe_kanban_card">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <br/>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="asset_type_id"/>
                                        </small>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a role="button" class="dropdown-toggle o-no-caret btn" data-toggle="dropdown" data-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <a role="menuitem" type="edit" class="dropdown-item">Editar</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-2">
                                    <div t-if="record.renewal_date.raw_value">
                                        <strong>Vencimiento: </strong> <field name="renewal_date"/>
                                    </div>
                                    <div t-if="record.valor_contable.raw_value">
                                        <strong>Valor Contable: </strong> <field name="valor_contable" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'por_expirar'" decoration-info="state == 'inactivo'" decoration-danger="state == 'expirado'"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="responsible_id" widget="many2one_avatar"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Window Action for Risk Kanban -->
        <record id="action_activo_intangible_risk" model="ir.actions.act_window">
            <field name="name">Matriz de Riesgos</field>
            <field name="res_model">activo.intangible</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="view_activo_intangible_risk_kanban"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Evaluación automatizada de riesgo de activos.
                </p>
                <p>
                    Los activos se clasifican por riesgo según su proximidad al vencimiento y su valor contable.
                </p>
            </field>
        </record>
    </data>
</odoo>
