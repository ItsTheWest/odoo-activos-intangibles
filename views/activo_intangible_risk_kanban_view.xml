<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ========================================================= -->
        <!-- KANBAN VIEW FOR RISK ANALYSIS                             -->
        <!-- ========================================================= -->
        <record id="view_activo_intangible_risk_kanban" model="ir.ui.view">
            <field name="name">activo.intangible.risk.kanban</field>
            <field name="model">activo.intangible</field>
            <field name="arch" type="xml">
                <kanban default_group_by="nivel_riesgo" class="o_kanban_small_column" records_draggable="true" quick_create="false">
                    <field name="name"/>
                    <field name="asset_type_id"/>
                    <field name="nivel_riesgo"/>
                    <field name="state"/>
                    <field name="valor_contable"/>
                    <field name="currency_id"/>
                    <field name="renewal_date"/>
                    <field name="responsible_id"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_global_click oe_kanban_card mb-3 p-3 shadow-sm border-0 rounded">
                                <div class="d-flex justify-content-between align-items-start w-100">
                                    <!-- Left side: Title, Type (Subtitle), and Status Badge -->
                                    <div class="o_kanban_record_headings flex-grow-1">
                                        <strong class="o_kanban_record_title d-block text-primary mb-1" style="font-size: 1.1em; line-height: 1.3;">
                                            <field name="name"/>
                                        </strong>
                                        <div class="text-muted mb-2" style="font-size: 0.9em;">
                                            <span class="fa fa-tag me-1"/> <field name="asset_type_id"/>
                                        </div>
                                        <div class="mb-1">
                                            <field name="state" widget="badge" decoration-success="state == 'activo'" decoration-warning="state == 'por_expirar'" decoration-info="state == 'inactivo'" decoration-danger="state == 'expirado'"/>
                                        </div>
                                    </div>
                                    <!-- Right side: Assign Responsible Avatar -->
                                    <div class="o_kanban_record_avatar ms-2 flex-shrink-0">
                                        <field name="responsible_id" widget="many2one_avatar"/>
                                    </div>
                                </div>

                                <!-- Body / Bottom: Valuation and Expiration Date separated by a subtle border -->
                                <div class="o_kanban_record_body border-top pt-2 mt-2" style="font-size: 0.85em;">
                                    <div class="d-flex justify-content-between align-items-center w-100">
                                        <div t-if="record.renewal_date.raw_value" class="text-muted">
                                            <span class="fa fa-calendar me-1"/> <strong>Vence:</strong> <field name="renewal_date"/>
                                        </div>
                                        <div t-if="record.valor_contable.raw_value" class="text-dark fw-bold">
                                            <field name="valor_contable" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Window Action for Risk Kanban -->
        <record id="action_activo_intangible_risk" model="ir.actions.act_window">
            <field name="name">Matriz de Riesgos</field>
            <field name="res_model">activo.intangible</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="view_activo_intangible_risk_kanban"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Evaluación automatizada de riesgo de activos.
                </p>
                <p>
                    Los activos se clasifican por riesgo según su proximidad al vencimiento y su valor contable.
                </p>
            </field>
        </record>
    </data>
</odoo>
