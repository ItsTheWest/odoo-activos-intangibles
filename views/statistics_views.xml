<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- ========================================================= -->
    <!-- 1. VISTA DE GRÁFICO (GRAPH VIEW)                          -->
    <!-- Muestra un gráfico de barras de los activos por tipo,    -->
    <!-- desglosado por estado. El usuario puede cambiar a pie     -->
    <!-- o línea usando los botones en la UI.                      -->
    <!-- ========================================================= -->
    <record id="view_activo_intangible_stats_graph" model="ir.ui.view">
      <field name="name">activo.intangible.stats.graph</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <graph string="Estadísticas de Activos Intangibles" type="bar" stacked="True">
          <!-- type="row": eje principal (eje X) -->
          <field name="asset_type" type="row"/>
          <!-- type="col": desglose por columna (color en el gráfico) -->
          <field name="state" type="col"/>
        </graph>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 2. VISTA PIVOT (PIVOT VIEW)                               -->
    <!-- Tabla de análisis matricial. Permite al usuario cruzar   -->
    <!-- dimensiones (tipo de activo vs. estado) de forma         -->
    <!-- interactiva y exportar a Excel.                           -->
    <!-- ========================================================= -->
    <record id="view_activo_intangible_stats_pivot" model="ir.ui.view">
      <field name="name">activo.intangible.stats.pivot</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <pivot string="Análisis de Activos Intangibles" display_quantity="true">
          <field name="asset_type" type="row"/>
          <field name="state" type="col"/>
        </pivot>
      </field>
    </record>

    <!-- ========================================================= -->
    <!-- 3. ACCIÓN DEDICADA PARA EL DASHBOARD DE ESTADÍSTICAS     -->
    <!-- Acción separada de la gestión de activos, que abre las   -->
    <!-- vistas de análisis por defecto.                           -->
    <!-- ========================================================= -->
    <record id="action_activo_intangible_statistics" model="ir.actions.act_window">
      <field name="name">Estadísticas de Activos</field>
      <field name="res_model">activo.intangible</field>
      <!-- El orden aquí importa: la primera vista es la que abre por defecto. -->
      <field name="view_mode">graph,pivot</field>
      <!-- Reutilizamos el search view definido en views.xml para los filtros. -->
      <field name="search_view_id" ref="view_activo_intangible_search"/>
      <!-- Contexto por defecto: el dashboard abre agrupado por estado y tipo. -->
      <field name="context">{
        'search_default_group_by_state': 1,
        'search_default_group_by_asset_type': 1
      }</field>
    </record>

    <!-- ========================================================= -->
    <!-- 4. MENÚ "ESTADÍSTICAS" BAJO EL MENÚ PADRE                -->
    <!-- Aparece como segunda opción bajo "Activos Intangibles"   -->
    <!-- en la barra superior de navegación.                       -->
    <!-- ========================================================= -->
    <menuitem
      id="menu_activo_intangible_statistics"
      name="Estadísticas"
      action="action_activo_intangible_statistics"
      parent="menu_activo_intangible_root"
      sequence="20"/>

  </data>
</odoo>
