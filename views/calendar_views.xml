<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ========================================================= -->
        <!-- VISTA DE CALENDARIO (CALENDAR VIEW)                       -->
        <!-- ========================================================= -->
        <record id="view_activo_intangible_calendar" model="ir.ui.view">
            <field name="name">activo.intangible.calendar</field>
            <field name="model">activo.intangible</field>
            <field name="arch" type="xml">
                <calendar string="Calendario de Vencimientos" date_start="renewal_date" color="state" mode="month">
                    <field name="name"/>
                    <field name="asset_type_id"/>
                    <field name="state"/>
                </calendar>
            </field>
        </record>


        <!-- Acción de ventana específica para el calendario -->
        <record id="action_activo_intangible_calendar" model="ir.actions.act_window">
            <field name="name">Calendario de Vencimientos</field>
            <field name="res_model">activo.intangible</field>
            <field name="view_mode">calendar,list,form</field>
            <field name="view_id" ref="view_activo_intangible_calendar"/>
        </record>

        <menuitem
            id="menu_activo_intangible_calendar"
            name="Calendario"
            action="action_activo_intangible_calendar"
            parent="menu_activo_intangible_root"
            sequence="20"/>
    </data>
</odoo>
