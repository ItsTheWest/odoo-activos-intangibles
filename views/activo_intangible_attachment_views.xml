<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================================ -->
    <!-- DIGITAL EVIDENCE VIEWS (ir.attachment extensions)                -->
    <!-- These views customise how the ir.attachment model is displayed   -->
    <!-- inside the Intangible Assets module (kanban, list, preview).     -->
    <!-- ================================================================ -->

    <!-- Custom Kanban: inherits the mail document kanban and injects
         the "Vista Previa" and custom "Eliminar" options in the card menu. -->
    <record id="view_attachment_custom_kanban" model="ir.ui.view">
      <field name="name">ir.attachment.custom.kanban</field>
      <field name="model">ir.attachment</field>
      <field name="inherit_id" ref="mail.view_document_file_kanban"/>
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <xpath expr="//t[@t-name='menu']" position="inside">
          <a type="object" name="action_preview_modal" class="dropdown-item">Vista Previa</a>
          <a type="delete" class="dropdown-item">Eliminar</a>
        </xpath>
      </field>
    </record>

    <!-- Custom List: shows attachments in a tabular format with
         action buttons for preview and deletion. -->
    <record id="view_attachment_custom_list" model="ir.ui.view">
      <field name="name">ir.attachment.custom.list</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <list string="Documentos Adjuntos">
          <field name="name"/>
          <field name="mimetype"/>
          <field name="create_date" string="Fecha de Carga"/>
          <button name="action_preview_modal" type="object"
                  string="Vista Previa" icon="fa-eye" class="btn-primary"/>
          <button type="delete" string="Eliminar" icon="fa-trash" class="btn-danger"/>
        </list>
      </field>
    </record>

    <!-- Modal Preview Form: read-only view that renders images inline
         and PDFs via the pdf_viewer widget.  Falls back to a warning
         message for unsupported MIME types. -->
    <record id="view_attachment_preview_form" model="ir.ui.view">
      <field name="name">ir.attachment.preview.form</field>
      <field name="model">ir.attachment</field>
      <field name="arch" type="xml">
        <form string="Vista Previa" create="false" edit="false" delete="false">
          <sheet>
            <div class="text-center">
              <h2 class="mb-4"><field name="name" readonly="1"/></h2>

              <!-- Image types -->
              <field name="datas" widget="image" readonly="1"
                     invisible="mimetype not in ('image/jpeg', 'image/png', 'image/gif', 'image/webp')"
                     style="max-width: 100%; height: auto; border-radius: 8px;"/>

              <!-- PDF -->
              <field name="datas" widget="pdf_viewer" readonly="1"
                     invisible="mimetype != 'application/pdf'"
                     style="width: 100%; height: 600px;"/>

              <!-- Unsupported type fallback -->
              <div invisible="mimetype in ('image/jpeg', 'image/png', 'image/gif', 'image/webp', 'application/pdf')"
                   class="alert alert-warning mt-4">
                <strong>Atención:</strong> No hay vista previa disponible para este tipo de archivo
                (<field name="mimetype" readonly="1"/>).
                Por favor, descargue el archivo.
              </div>
            </div>
          </sheet>
          <footer>
            <button string="Cerrar" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

  </data>
</odoo>
