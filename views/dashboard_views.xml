<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================================= -->
    <!-- DASHBOARD FORM VIEW                                             -->
    <!-- KPI containers above + embedded high-performance SVG charts below.-->
    <!-- ================================================================= -->
    <record id="view_activo_intangible_dashboard_form" model="ir.ui.view">
      <field name="name">activo.intangible.dashboard.form</field>
      <field name="model">activo.intangible.dashboard</field>
      <field name="arch" type="xml">
        <form string="Panel de Estadísticas" create="false" edit="false" delete="false">

          <div class="o_form_view">

            <!-- ── KPI CARDS ROW ── -->
            <div class="container-fluid mt-3 mb-3">

              <!-- Row 1: Financial -->
              <div class="row mb-3">
                <!-- Valoración Total — accent: #2d9b5e (green) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_all" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #2d9b5e; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-dollar fa-2x me-2" style="color:#2d9b5e;"/>
                          <span class="text-uppercase small fw-bold" style="color:#1a6b3c;">Valoración Total</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#1a6b3c;">
                          <field name="valoracion_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#4caf85;">Valor contable total de todos los activos</p>
                      </div>
                    </div>
                  </button>
                </div>

                <!-- Total Activos — accent: #3a7bd5 (blue) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_all" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #3a7bd5; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-archive fa-2x me-2" style="color:#3a7bd5;"/>
                          <span class="text-uppercase small fw-bold" style="color:#1155cc;">Total Registrados</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#1155cc;">
                          <field name="total_activos"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#6a9ee0;">Activos intangibles en el sistema</p>
                      </div>
                    </div>
                  </button>
                </div>

                <!-- Activos Activos — accent: #27ae60 (emerald) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_active" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #27ae60; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-check-circle fa-2x me-2" style="color:#27ae60;"/>
                          <span class="text-uppercase small fw-bold" style="color:#145a32;">Activos</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#145a32;">
                          <field name="activos_activos"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#52c584;">En estado Activo y vigentes</p>
                      </div>
                    </div>
                  </button>
                </div>
              </div>

              <!-- Row 2: Alerts -->
              <div class="row mb-3">
                <!-- Por Expirar — accent: #e67e22 (orange) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_expiring" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #e67e22; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-exclamation-triangle fa-2x me-2" style="color:#e67e22;"/>
                          <span class="text-uppercase small fw-bold" style="color:#9c5700;">Por Expirar</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#9c5700;">
                          <field name="activos_por_expirar"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#d4934a;">Vencen en los próximos 60 días</p>
                      </div>
                    </div>
                  </button>
                </div>

                <!-- Expirados — accent: #c0392b (red) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_expired" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #c0392b; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-times-circle fa-2x me-2" style="color:#c0392b;"/>
                          <span class="text-uppercase small fw-bold" style="color:#7b1a1a;">Expirados</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#7b1a1a;">
                          <field name="activos_expirados"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#d4695d;">Requieren renovación urgente</p>
                      </div>
                    </div>
                  </button>
                </div>

                <!-- Inactivos — accent: #2980b9 (steel blue) -->
                <div class="col-12 col-md-4 mb-2">
                  <button name="action_view_inactive" type="object" class="o_dashboard_card_btn w-100 h-100 p-0 border-0 bg-transparent text-start">
                    <div class="card h-100 shadow-sm" style="background:#ffffff; border: 2px solid #2980b9; border-radius: 10px;">
                      <div class="card-body">
                        <div class="d-flex align-items-center mb-1">
                          <i class="fa fa-pause-circle fa-2x me-2" style="color:#2980b9;"/>
                          <span class="text-uppercase small fw-bold" style="color:#1a3a5c;">Inactivos</span>
                        </div>
                        <h3 class="card-title fw-bold mb-0" style="color:#1a3a5c;">
                          <field name="activos_inactivos"/>
                        </h3>
                        <p class="card-text small mt-1" style="color:#5ba3d0;">Activos desactivados temporalmente</p>
                      </div>
                    </div>
                  </button>
                </div>
              </div>

            </div><!-- /container-fluid KPIs -->

            <field name="currency_id" invisible="1"/>

            <!-- ================================================================= -->
            <!-- ANÁLISIS DETALLADO: DYNAMIC SVG CHARTS                           -->
            <!-- ================================================================= -->
            <div class="container-fluid mb-4">

              <div class="row mb-3">
                <div class="col-12">
                  <h5 class="fw-bold text-muted mb-0">
                    <i class="fa fa-chart-bar me-2"/>
                    Análisis Detallado
                  </h5>
                  <hr class="mt-2"/>
                </div>
              </div>

              <div class="row">
                <!-- CHART 1: Distribución por Estado -->
                <div class="col-12 col-lg-6 mb-4">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-bar-chart me-2 text-primary"/>
                        Distribución por Estado
                      </span>
                    </div>
                    <div class="card-body p-3" style="height: 260px;">
                      <!-- OWL Chart.js widget — fetches live data via orm.readGroup -->
                      <widget name="estado_bar_chart"/>
                    </div>
                  </div>
                </div>

                <!-- CHART 2: Composición por Tipo -->
                <div class="col-12 col-lg-6 mb-4">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-pie-chart me-2 text-success"/>
                        Composición por Tipo de Activo
                      </span>
                    </div>
                    <div class="card-body p-3" style="height: 260px;">
                      <!-- OWL Chart.js widget — replaces legacy SVG -->
                      <widget name="tipo_activo_pie_chart"/>
                    </div>
                  </div>
                </div>
              </div>

              <!-- CHART 3: Historical Valuation Trend -->
              <div class="row mb-4">
                <div class="col-12">
                  <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-line-chart me-2 text-primary"/>
                        Tendencia de Valoración Histórica ($)
                      </span>
                      <small class="text-muted">Crecimiento acumulado del portafolio</small>
                    </div>
                    <div class="card-body p-3" style="height: 320px;">
                      <!-- OWL Chart.js widget — replaces legacy SVG -->
                      <widget name="tendencia_line_chart"/>
                    </div>
                  </div>
                </div>
              </div>

              <!-- CHART 4: Próximos Vencimientos (6 meses) -->
              <div class="row mb-4">
                <div class="col-12">
                  <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-calendar-check-o me-2 text-info"/>
                        Próximos Vencimientos (6 meses)
                      </span>
                    </div>
                    <div class="card-body p-3" style="height: 300px;">
                      <!-- OWL Chart.js widget — replaces legacy SVG -->
                      <widget name="vencimientos_bar_chart"/>
                    </div>
                  </div>
                </div>
              </div>

            </div><!-- /container-fluid charts -->

          </div><!-- /o_form_view -->
        </form>
      </field>
    </record>

    <!-- SERVER ACTION TO OPEN DASHBOARD -->
    <record id="action_server_activo_intangible_dashboard" model="ir.actions.server">
      <field name="name">Ver Estadísticas</field>
      <field name="model_id" ref="model_activo_intangible_dashboard"/>
      <field name="state">code</field>
      <field name="code">
        action = model.action_open_dashboard()
      </field>
    </record>

  </data>
</odoo>
