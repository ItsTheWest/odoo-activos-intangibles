<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================================= -->
    <!-- DASHBOARD FORM VIEW                                             -->
    <!-- KPI containers above + embedded high-performance SVG charts below.-->
    <!-- ================================================================= -->
    <record id="view_activo_intangible_dashboard_form" model="ir.ui.view">
      <field name="name">activo.intangible.dashboard.form</field>
      <field name="model">activo.intangible.dashboard</field>
      <field name="arch" type="xml">
        <form string="Panel de Estadísticas" create="false" delete="false">

          <div class="o_form_view">

            <!-- ── KPI CARDS ROW ── -->
            <div class="container-fluid mt-3 mb-3">

              <!-- Row 1: Financial -->
              <div class="row mb-3">
                <!-- Valoración Total -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1a6b3c 0%, #2d9b5e 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-dollar-sign fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Valoración Total</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="valoracion_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">Valor contable total de todos los activos</p>
                    </div>
                  </div>
                </div>

                <!-- Total Activos -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1155cc 0%, #3a7bd5 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-archive fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Total Registrados</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="total_activos"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">Activos intangibles en el sistema</p>
                    </div>
                  </div>
                </div>

                <!-- Activos Activos -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #145a32 0%, #27ae60 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-check-circle fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Activos</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="activos_activos"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">En estado Activo y vigentes</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Row 2: Alerts -->
              <div class="row mb-3">
                <!-- Por Expirar -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #9c5700 0%, #e67e22 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-exclamation-triangle fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Por Expirar</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="activos_por_expirar"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">Vencen en los próximos 60 días</p>
                    </div>
                  </div>
                </div>

                <!-- Expirados -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #7b1a1a 0%, #c0392b 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-times-circle fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Expirados</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="activos_expirados"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">Requieren renovación urgente</p>
                    </div>
                  </div>
                </div>

                <!-- Inactivos -->
                <div class="col-12 col-md-4 mb-2">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(135deg, #1a3a5c 0%, #2980b9 100%);">
                    <div class="card-body text-white">
                      <div class="d-flex align-items-center mb-1">
                        <i class="fa fa-pause-circle fa-2x me-2 opacity-75"/>
                        <span class="text-uppercase small fw-bold opacity-75">Inactivos</span>
                      </div>
                      <h3 class="card-title fw-bold mb-0">
                        <field name="activos_inactivos"/>
                      </h3>
                      <p class="card-text small opacity-75 mt-1">Activos desactivados temporalmente</p>
                    </div>
                  </div>
                </div>
              </div>

            </div><!-- /container-fluid KPIs -->

            <field name="currency_id" invisible="1"/>

            <!-- ================================================================= -->
            <!-- ANÁLISIS DETALLADO: DYNAMIC SVG CHARTS                           -->
            <!-- ================================================================= -->
            <div class="container-fluid mb-4">

              <div class="row mb-3">
                <div class="col-12">
                  <h5 class="fw-bold text-muted mb-0">
                    <i class="fa fa-chart-bar me-2"/>
                    Análisis Detallado
                  </h5>
                  <hr class="mt-2"/>
                </div>
              </div>

              <div class="row">
                <!-- CHART 1: Distribución por Estado -->
                <div class="col-12 col-lg-6 mb-4">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-bar-chart me-2 text-primary"/>
                        Distribución por Estado
                      </span>
                      <button name="action_ver_grafico" type="object"
                              class="btn btn-sm btn-outline-primary">
                        <i class="fa fa-external-link me-1"/> Ver completo
                      </button>
                    </div>
                    <div class="card-body p-3">
                      <field name="graph_estado_svg" widget="html" nolabel="1"/>
                    </div>
                  </div>
                </div>

                <!-- CHART 2: Composición por Tipo -->
                <div class="col-12 col-lg-6 mb-4">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-pie-chart me-2 text-success"/>
                        Composición por Tipo de Activo
                      </span>
                      <button name="action_ver_grafico_tipo" type="object"
                              class="btn btn-sm btn-outline-success">
                        <i class="fa fa-external-link me-1"/> Ver completo
                      </button>
                    </div>
                    <div class="card-body p-3">
                      <field name="graph_tipo_svg" widget="html" nolabel="1"/>
                    </div>
                  </div>
                </div>
              </div>

              <!-- CHART 3: Línea de Tiempo / Información Adicional -->
              <div class="row mb-4">
                <div class="col-12">
                  <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-info-circle me-2 text-info"/>
                        Estado General del Repositorio
                      </span>
                      <button name="action_ver_pivot" type="object"
                              class="btn btn-sm btn-outline-info">
                        <i class="fa fa-table me-1"/> Explorar Datos
                      </button>
                    </div>
                    <div class="card-body p-0">
                      <field name="graph_vencimientos_svg" widget="html" nolabel="1"/>
                    </div>
                  </div>
                </div>
              </div>

            </div><!-- /container-fluid charts -->

          </div><!-- /o_form_view -->
        </form>
      </field>
    </record>

    <!-- ACTION -->
    <record id="action_activo_intangible_dashboard" model="ir.actions.act_window">
      <field name="name">Estadísticas de Activos</field>
      <field name="res_model">activo.intangible.dashboard</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="view_activo_intangible_dashboard_form"/>
      <field name="target">current</field>
      <field name="context">{'create': True}</field>
    </record>

  </data>
</odoo>
