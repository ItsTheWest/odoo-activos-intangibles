<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================================= -->
    <!-- DASHBOARD FORM VIEW                                                 -->
    <!-- Each card contains the KPI metric AND its corresponding SVG chart  -->
    <!-- inline — no redirects, no separate views.                           -->
    <!-- ================================================================= -->
    <record id="view_activo_intangible_dashboard_form" model="ir.ui.view">
      <field name="name">activo.intangible.dashboard.form</field>
      <field name="model">activo.intangible.dashboard</field>
      <field name="arch" type="xml">
        <form string="Panel de Estadísticas" create="false" delete="false">

          <div class="o_form_view">

            <field name="currency_id" invisible="1"/>

            <!-- ============================================================= -->
            <!-- ROW 1: Financial Summary + Distribution by State (Bar Chart)   -->
            <!-- ============================================================= -->
            <div class="container-fluid mt-3 mb-3">
              <div class="row">

                <!-- Card 1: Valoración Total + Total Activos -->
                <div class="col-12 col-lg-3 mb-3">
                  <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(160deg, #1a3a5c 0%, #2980b9 100%);">
                    <div class="card-body text-white d-flex flex-column">
                      <span class="text-uppercase small fw-bold opacity-75 mb-2">
                        <i class="fa fa-archive me-1"/> Total Registrados
                      </span>
                      <h2 class="fw-bold mb-0">
                        <field name="total_activos"/>
                      </h2>
                      <p class="small opacity-75 mt-1 mb-3">Activos en el sistema</p>
                      <hr class="border-white opacity-25 my-0"/>
                      <div class="mt-2">
                        <span class="text-uppercase small fw-bold opacity-75">
                          <i class="fa fa-dollar-sign me-1"/> Valoración Total
                        </span>
                        <h4 class="fw-bold mb-0 mt-1">
                          <field name="valoracion_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </h4>
                        <p class="small opacity-75 mt-1 mb-0">Valor contable del portafolio</p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Card 2: Distribución por Estado — KPI numbers + Bar Chart inside -->
                <div class="col-12 col-lg-9 mb-3">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-bar-chart me-2 text-primary"/>
                        Distribución por Estado
                      </span>
                    </div>
                    <div class="card-body p-0">
                      <!-- KPI row inside card -->
                      <div class="row g-0 border-bottom">
                        <div class="col-3 text-center p-3 border-end">
                          <div class="small text-muted mb-1">
                            <i class="fa fa-check-circle me-1" style="color:#27ae60"/>
                            Activos
                          </div>
                          <h3 class="fw-bold mb-0" style="color:#27ae60;">
                            <field name="activos_activos"/>
                          </h3>
                        </div>
                        <div class="col-3 text-center p-3 border-end">
                          <div class="small text-muted mb-1">
                            <i class="fa fa-exclamation-triangle me-1" style="color:#e67e22"/>
                            Por Expirar
                          </div>
                          <h3 class="fw-bold mb-0" style="color:#e67e22;">
                            <field name="activos_por_expirar"/>
                          </h3>
                        </div>
                        <div class="col-3 text-center p-3 border-end">
                          <div class="small text-muted mb-1">
                            <i class="fa fa-times-circle me-1" style="color:#c0392b"/>
                            Expirados
                          </div>
                          <h3 class="fw-bold mb-0" style="color:#c0392b;">
                            <field name="activos_expirados"/>
                          </h3>
                        </div>
                        <div class="col-3 text-center p-3">
                          <div class="small text-muted mb-1">
                            <i class="fa fa-pause-circle me-1" style="color:#2980b9"/>
                            Inactivos
                          </div>
                          <h3 class="fw-bold mb-0" style="color:#2980b9;">
                            <field name="activos_inactivos"/>
                          </h3>
                        </div>
                      </div>
                      <!-- Bar Chart embedded below the KPIs inside the same card -->
                      <div class="p-2">
                        <field name="graph_estado_svg" widget="html" nolabel="1"/>
                      </div>
                    </div>
                  </div>
                </div>

              </div><!-- /row 1 -->

              <!-- ============================================================= -->
              <!-- ROW 2: Donut Chart by Type + Timeline of Expirations           -->
              <!-- ============================================================= -->
              <div class="row">

                <!-- Card 3: Composición por Tipo — Donut Chart inside -->
                <div class="col-12 col-lg-5 mb-3">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-pie-chart me-2 text-success"/>
                        Composición por Tipo de Activo
                      </span>
                    </div>
                    <div class="card-body p-2">
                      <field name="graph_tipo_svg" widget="html" nolabel="1"/>
                    </div>
                  </div>
                </div>

                <!-- Card 4: Vencimientos próximos — Timeline Line Chart inside -->
                <div class="col-12 col-lg-7 mb-3">
                  <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                      <span class="fw-semibold">
                        <i class="fa fa-calendar me-2 text-warning"/>
                        Proyección de Vencimientos (Próximos 6 meses)
                      </span>
                    </div>
                    <div class="card-body p-2">
                      <field name="graph_vencimientos_svg" widget="html" nolabel="1"/>
                    </div>
                  </div>
                </div>

              </div><!-- /row 2 -->

            </div><!-- /container-fluid -->

          </div><!-- /o_form_view -->
        </form>
      </field>
    </record>

    <!-- ACTION -->
    <record id="action_activo_intangible_dashboard" model="ir.actions.act_window">
      <field name="name">Estadísticas de Activos</field>
      <field name="res_model">activo.intangible.dashboard</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="view_activo_intangible_dashboard_form"/>
      <field name="target">current</field>
      <field name="context">{'create': True}</field>
    </record>

  </data>
</odoo>
