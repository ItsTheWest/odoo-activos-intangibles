<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ================================================================
         REPOSITORIO DE EVIDENCIAS DIGITALES
         ================================================================
         This file registers the "Repositorio" section of the module.

         Design decision: we use a KANBAN view so each asset appears as
         a visual card/container. Clicking a card opens the form directly
         on the "Evidencias Digitales" tab so the user can manage files.

         Cards are colour-coded:
           • Grey border  → 0 documents (needs attention)
           • Green border → has documents (compliant)
         ================================================================ -->

    <!-- =================================================================
         1. KANBAN VIEW — "Repositorio de Evidencias"
         Each asset rendered as a card showing key info + document count.
         Clicking the card opens the record form (evidence tab).
         ================================================================= -->
    <record id="view_evidence_repository_kanban" model="ir.ui.view">
      <field name="name">activo.intangible.evidence.kanban</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <kanban class="o_kanban_mobile" default_group_by="asset_type_id">
          <field name="name"/>
          <field name="asset_type_id"/>
          <field name="registration_number"/>
          <field name="renewal_date"/>
          <field name="responsible_id"/>
          <field name="state"/>
          <field name="document_count"/>
          <templates>
            <t t-name="card">
              <!-- Card container: red-left-border when 0 docs, green when > 0 -->
              <div t-attf-class="d-flex flex-column p-2"
                   t-att-style="record.document_count.raw_value == 0 ? 'border-left: 4px solid #dc3545;' : 'border-left: 4px solid #28a745;'">

                <!-- Row 1: Asset name + state badge -->
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <strong class="o_kanban_record_title text-truncate">
                    <field name="name"/>
                  </strong>
                  <field name="state" widget="badge"
                         decoration-success="state == 'activo'"
                         decoration-info="state == 'inactivo'"
                         decoration-danger="state == 'expirado'"/>
                </div>

                <!-- Row 2: Type + Registration number -->
                <div class="d-flex gap-2 text-muted small mb-1">
                  <span><i class="fa fa-tag me-1"/><field name="asset_type_id"/></span>
                  <span t-if="record.registration_number.value">
                    <i class="fa fa-hashtag me-1"/><field name="registration_number"/>
                  </span>
                </div>

                <!-- Row 3: Renewal date + Responsible -->
                <div class="d-flex justify-content-between align-items-center small">
                  <span class="text-muted" t-if="record.renewal_date.value">
                    <i class="fa fa-calendar me-1"/>Vence: <field name="renewal_date"/>
                  </span>
                  <span t-if="record.responsible_id.value">
                    <field name="responsible_id" widget="many2one_avatar_user"/>
                  </span>
                </div>

                <!-- Row 4: Document count — focal indicator -->
                <div class="d-flex align-items-center mt-2 pt-2" style="border-top: 1px solid #dee2e6;">
                  <i class="fa fa-paperclip me-1"/>
                  <span t-if="record.document_count.raw_value == 0"
                        class="text-danger fw-bold">
                    Sin documentos adjuntos
                  </span>
                  <span t-else="" class="text-success fw-bold">
                    <field name="document_count"/> documento(s) adjunto(s)
                  </span>
                </div>

              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Keep the list view as a fallback for users who prefer tabular data -->
    <record id="view_evidence_repository_list" model="ir.ui.view">
      <field name="name">activo.intangible.evidence.list</field>
      <field name="model">activo.intangible</field>
      <field name="arch" type="xml">
        <list string="Repositorio de Evidencias Digitales"
              decoration-danger="document_count == 0"
              decoration-success="document_count &gt; 0">
          <field name="name" string="Activo"/>
          <field name="asset_type_id" string="Tipo"/>
          <field name="registration_number" string="N° Registro"/>
          <field name="renewal_date" string="Vence"/>
          <field name="responsible_id" widget="many2one_avatar" string="Responsable"/>
          <field name="state"
                 widget="badge"
                 decoration-success="state == 'activo'"
                 decoration-info="state == 'inactivo'"
                 decoration-danger="state == 'expirado'"
                 string="Estado"/>
          <field name="document_count" string="Documentos adjuntos"/>
        </list>
      </field>
    </record>

    <!-- =================================================================
         2. WINDOW ACTION — "Repositorio de Evidencias"
         Opens with Kanban first (visual card overview), then list, then
         form for drilling into a record's evidence tab.
         Default grouping by asset_type_id gives an organised view.
         ================================================================= -->
    <record id="action_evidence_repository" model="ir.actions.act_window">
      <field name="name">Repositorio de Evidencias</field>
      <field name="res_model">activo.intangible</field>
      <!-- kanban first for card view; list as alternative; form to drill in -->
      <field name="view_mode">kanban,list,form</field>
      <!-- Reuse the standard search view (filters, groupBy) from views.xml -->
      <field name="search_view_id" ref="view_activo_intangible_search"/>
      <!-- Default grouping by type gives an organised compliance overview -->
      <field name="context">{'search_default_group_by_asset_type': 1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          No hay activos registrados aún.
        </p>
        <p>
          Crea un activo intangible y adjunta su contrato o licencia en la pestaña
          <strong>Evidencias Digitales</strong>.
        </p>
      </field>
    </record>

    <!-- Bind specific views to the action in the correct order -->
    <record id="action_evidence_repository_kanban_view" model="ir.actions.act_window.view">
      <field name="act_window_id" ref="action_evidence_repository"/>
      <field name="view_id" ref="view_evidence_repository_kanban"/>
      <field name="view_mode">kanban</field>
      <field name="sequence">1</field>
    </record>

    <record id="action_evidence_repository_list_view" model="ir.actions.act_window.view">
      <field name="act_window_id" ref="action_evidence_repository"/>
      <field name="view_id" ref="view_evidence_repository_list"/>
      <field name="view_mode">list</field>
      <field name="sequence">2</field>
    </record>

    <record id="action_evidence_repository_form_view" model="ir.actions.act_window.view">
      <field name="act_window_id" ref="action_evidence_repository"/>
      <field name="view_id" ref="view_activo_intangible_form"/>
      <field name="view_mode">form</field>
      <field name="sequence">3</field>
    </record>

    <!-- =================================================================
         3. MENU ITEM — "Repositorio"
         Placed at sequence=15 so it sits between "Activos" (seq=10)
         and "Estadísticas" (seq=20) in the top navigation bar.
         ================================================================= -->
    <menuitem
      id="menu_evidence_repository"
      name="Repositorio"
      action="action_evidence_repository"
      parent="menu_activo_intangible_root"
      sequence="15"/>

  </data>
</odoo>
